<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Тулбар -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/chat_title"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Основной контент (горизонтальный для сплит-вида на планшете) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- ═══ ЛЕВАЯ ПАНЕЛЬ: список клиентов (только для администратора) ═══ -->
        <LinearLayout
            android:id="@+id/panelConversations"
            android:layout_width="260dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@color/surface">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Клиенты"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:background="@color/primary_container" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvConversations"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Разделитель между панелями -->
        <View
            android:id="@+id/dividerPanels"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider"
            android:visibility="gone" />

        <!-- ═══ ПРАВАЯ ПАНЕЛЬ: переписка ═══ -->
        <LinearLayout
            android:id="@+id/panelChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Подсказка для администратора: выберите клиента -->
            <TextView
                android:id="@+id/tvSelectClient"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="← Выберите клиента из списка"
                android:gravity="center"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />

            <!-- Сообщения -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <!-- Пустое состояние (клиент, нет сообщений) -->
            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/chat_empty"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <!-- Поле ввода -->
            <LinearLayout
                android:id="@+id/layoutInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/surface"
                android:padding="8dp"
                android:elevation="4dp"
                android:gravity="center_vertical">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="@string/message_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:maxLines="4" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSend"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:backgroundTint="@color/primary"
                    app:icon="@drawable/ic_chat"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    android:contentDescription="@string/send" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
